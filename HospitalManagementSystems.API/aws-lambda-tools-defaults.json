{
  "Information": "This file is used to store default settings for the AWS Lambda deployment. Values here are used by the 'dotnet lambda' CLI tool.",

  "profile": "",
  "region": "us-east-1",

  "configuration": "Release",
  "framework": "net6.0",

  "s3-bucket": "hms-lambda-deployments",
